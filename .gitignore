# Dependencies
/vendor/
/node_modules/
# Python virtualenv — used only for the live trigger-eval runner
# (anthropic SDK). Never commit.
/.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# PHP
.phpunit.cache/
composer.lock

# Python
__pycache__/
*.pyc

# Temp
/tmp/

# Playwright
/.playwright-mcp/*

# Ignore the agent settings (YAML is the active format; flat legacy is
# kept for the migration window and gets deleted by scripts/install once
# the YAML file has been written)
.agent-settings.yml
.agent-settings
.agent-settings.backup.key-value

# Persistent chat-history log (crash recovery; written by
# scripts/chat_history.py, governed by the chat-history rule). Never
# commit — contains conversation content and session fingerprints.
.agent-chat-history
.agent-chat-history.bak
.agent-chat-history.*.bak
.agent-chat-history.session

# Artefact engagement telemetry log (default-off, maintainer-only;
# written by `./agent-config telemetry:record` when
# `telemetry.artifact_engagement.enabled: true`). Local-only —
# never commit.
.agent-engagement.jsonl
.agent-engagement.jsonl.bak

# Generated Augment Code projection of .agent-src/ (rebuilt by `task sync`)
/.augment/

# Dispatcher run results (produced by `dispatcher run --output …`, consumed by ci_summary)
/agents/reports/runs/

# Trigger-eval run outputs (produced by `scripts/skill_trigger_eval.py`;
# triggers.json is tracked, last-run.json is per-run output)
.agent-src.uncompressed/skills/*/evals/last-run.json
.agent-src/skills/*/evals/last-run.json
# Live trigger-eval outputs — timestamped JSON per run, not committed.
evals/results/

# Memory access runtime cache (per-repo `memory_status` probe result;
# regenerated on demand, never committed)
/.agent-memory/

# /implement-ticket run metrics (JSON lines per run, Q38 ✅ decided).
# Opt-in to commit for team review — default is local-only.
/agents/logs/implement-ticket/

# Phase 5.3 always-rule budget trend log (per-run JSONL, local-only).
/.github/budget-trend.jsonl

# Golden Transcript freeze-guard staging output (produced by
# `python3 -m tests.golden.capture --target tests/golden/.staging`,
# diffed against the committed baseline; never committed).
/tests/golden/.staging/
/tests/golden/.staging-*.txt
# Safety net: catch any alternative dot-prefixed staging variants
# (e.g. `.gt-staging/` debris from earlier capture iterations).
/tests/golden/.gt-*

# Cloud bundle output
/dist/

# AI Council runtime price cache (refreshed weekly by
# `python3 scripts/update_prices.py`; bootstrapped on first /council
# call from scripts/ai_council/_default_prices.py). User-editable —
# never commit, prices drift constantly.
.agent-prices.md

# AI Council session persistence (D2). Each /council run writes
# request + raw responses + manifest to a per-UTC-timestamp folder
# for local audit + replay. Contains real provider output and
# user-pasted manual replies — never commit.
agents/council-sessions/

# Tier 1 hook runtime state (context-hygiene.json, onboarding-gate.json).
# Written by SessionStart / PostToolUse hooks on Augment + Claude Code;
# regenerated on demand, never committed.
/agents/state/
