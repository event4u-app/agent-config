# Dependencies
/vendor/
/node_modules/
# Python virtualenv — used only for the live trigger-eval runner
# (anthropic SDK). Never commit.
/.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# PHP
.phpunit.cache/
composer.lock

# Python
__pycache__/
*.pyc

# Temp
/tmp/

# Ignore the agent settings (YAML is the active format; flat legacy is
# kept for the migration window and gets deleted by scripts/install once
# the YAML file has been written)
.agent-settings.yml
.agent-settings
.agent-settings.backup.key-value

# Generated Augment Code projection of .agent-src/ (rebuilt by `task sync`)
/.augment/

# Dispatcher run results (produced by `dispatcher run --output …`, consumed by ci_summary)
/agents/reports/runs/

# Trigger-eval run outputs (produced by `scripts/skill_trigger_eval.py`;
# triggers.json is tracked, last-run.json is per-run output)
.agent-src.uncompressed/skills/*/evals/last-run.json
.agent-src/skills/*/evals/last-run.json
# Live trigger-eval outputs — timestamped JSON per run, not committed.
evals/results/

# Memory access runtime cache (per-repo `memory_status` probe result;
# regenerated on demand, never committed)
/.agent-memory/

# /implement-ticket run metrics (JSON lines per run, Q38 ✅ decided).
# Opt-in to commit for team review — default is local-only.
/agents/logs/implement-ticket/
