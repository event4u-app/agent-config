{
  "mcpServers": {
    "github": {
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "command": "npx",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_xxx"
      }
    },
    "jira": {
      "args": ["run", "--rm", "-i", "mcp/jira:latest"],
      "command": "docker",
      "cwd": "/workspace",
      "env": {
        "JIRA_HOST": "example.atlassian.net",
        "JIRA_TOKEN": "jira_yyy"
      }
    }
  }
}
