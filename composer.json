{
    "name": "event4u/agent-config",
    "description": "Shared Augment agent configuration — skills, rules, commands, guidelines, and templates for projects",
    "type": "composer-plugin",
    "license": "proprietary",
    "require": {
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Event4u\\AgentConfig\\": "src/"
        }
    },
    "extra": {
        "class": "Event4u\\AgentConfig\\AgentConfigPlugin"
    },
    "archive": {
        "exclude": [
            "/.augment.uncompressed",
            "/agents",
            "/scripts",
            "/tests",
            "/Makefile",
            "/.github",
            "/.idea"
        ]
    }
}
