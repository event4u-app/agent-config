{
    "name": "event4u/agent-config",
    "description": "Shared agent configuration — skills, rules, commands, guidelines, and templates for AI coding tools",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.0"
    },
    "bin": [
        "bin/install.php",
        "scripts/agent-config"
    ],
    "archive": {
        "exclude": [
            "/.agent-src.uncompressed",
            "/.compression-hashes.json",
            "/agents",
            "/tests",

            "/Taskfile.yml",
            "/.github",
            "/.idea",
            "/.claude",
            "/.cursor",
            "/.clinerules",
            "/.windsurfrules",
            "/GEMINI.md"
        ]
    }
}
