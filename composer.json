{
    "name": "event4u/agent-config",
    "description": "Shared Augment agent configuration — skills, rules, commands, guidelines, and templates for projects",
    "type": "composer-plugin",
    "license": "proprietary",
    "require": {
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Event4u\\AgentConfig\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Event4u\\AgentConfig\\Tests\\": "tests/"
        }
    },
    "extra": {
        "class": "Event4u\\AgentConfig\\AgentConfigPlugin"
    },
    "archive": {
        "exclude": [
            "/.augment.uncompressed",
            "/.compression-hashes.json",
            "/agents",
            "/scripts",
            "/tests",

            "/Taskfile.yml",
            "/.github",
            "/.idea",
            "/.claude",
            "/.cursor",
            "/.clinerules",
            "/.windsurfrules",
            "/GEMINI.md"
        ]
    }
}
